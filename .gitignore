# =========================
# Python cache / bytecode
# =========================
__pycache__/
*.py[cod]
*$py.class

# =========================
# Virtual environments
# =========================
.venv/
venv/
env/
ENV/

# =========================
# Packaging / build outputs
# =========================
build/
dist/
*.egg-info/
.eggs/

# =========================
# Test / coverage artifacts
# =========================
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/

# =========================
# Jupyter checkpoints
# =========================
.ipynb_checkpoints/

# =========================
# IDE/editor files
# =========================
.vscode/
.idea/
*.swp
*.swo

# =========================
# OS files
# =========================
.DS_Store
Thumbs.db

# =========================
# Runtime logs
# =========================
logs/*.log
*.log

# =========================
# Project-generated ML artifacts
# Keep source code + raw datasets, ignore regenerated outputs
# =========================
artifacts/**
!artifacts/.gitkeep

# Optional local exports / temp files
*.tmp
*.temp

# =========================
# Environment secrets
# =========================
.env
.env.*
IPL.csv

# =========================
# DVC cache
# =========================
.dvc/cache/
